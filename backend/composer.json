{
    "name": "agriri/backend",
    "type": "project",
    "description": "Agriri — Real-Time Agricultural Extension and Farm Incident Response Platform for Ilocos Norte",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.9",
        "phpoffice/phpspreadsheet": "^2.3",
        "barryvdh/laravel-dompdf": "^3.1",
        "intervention/image": "^3.9",
        "google/apiclient": "^2.18"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "App\\": "app/", "Database\\Factories\\": "database/factories/", "Database\\Seeders\\": "database/seeders/" }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "config": {
        "optimize-autoloader": false,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

APP_NAME=AgriConnect-IN
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Manila
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=agriri
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
QUEUE_CONNECTION=database
CACHE_STORE=database

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1:5173
SANCTUM_TOKEN_PREFIX=agriri_

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@agriri.gov.ph"
MAIL_FROM_NAME="AgriConnect-IN"

FILESYSTEM_DISK=public

FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json

# Gmail API (works on Railway — SMTP ports 587/465 are blocked)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_SENDER=
GMAIL_SENDER_NAME="AgriConnect-IN"
